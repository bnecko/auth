AUTH_BASE_URL=https://auth.bneck.com
CLOUDFLARED_TOKEN=

# Which proxy header to trust for the client IP (per-IP rate limiting and
# audit logs). "cf" trusts cf-connecting-ip, "xff" trusts x-real-ip /
# x-forwarded-for. Required in production: when unset, the client IP is
# treated as unknown and every visitor shares one rate-limit bucket. This
# deployment is reachable only via the Cloudflare tunnel, so "cf" is correct.
TRUSTED_PROXY=cf

POSTGRES_PASSWORD=change-this-before-deploy
DATABASE_URL=postgres://auth:change-this-before-deploy@localhost:5432/auth
DATABASE_POOL_MAX=4
APP_NODE_OPTIONS=--max-old-space-size=256

SESSION_MAX_AGE_SECONDS=2592000
SESSION_SHORT_AGE_SECONDS=43200
REGISTRATION_TTL_MINUTES=15
ACTIVATION_TTL_MINUTES=10
LOGIN_2FA_TTL_MINUTES=5

OIDC_PRIVATE_KEY_PEM=
OIDC_KEY_ID=default
OIDC_SIGNING_KEYS_JSON=
OAUTH_DYNAMIC_REGISTRATION_TOKEN=
OAUTH_ACCESS_TOKEN_TTL_SECONDS=900
# Required in production. HMAC key for stateless OAuth-authorize CSRF tokens.
# Must be cryptographically random and distinct from OIDC_PRIVATE_KEY_PEM
# (NIST SP 800-57 key-separation). Generate with: openssl rand -hex 32
OAUTH_CSRF_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=bottleneck_auth_bot
TELEGRAM_BOT_WEBHOOK_SECRET=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=bottleneck_auth_bot

TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

TELEGRAM_ANALYTICS_CHAT_ID=
TELEGRAM_ANALYTICS_THREAD_ID=
INTERNAL_ANALYTICS_SECRET=

# Transactional email (verification codes) via Resend. Required in the app
# process for email verification to send; the sending domain (bneck.com) must
# be verified in Resend with SPF/DKIM DNS records. EMAIL_FROM_ADDRESS defaults
# to "bottleneck <noreply@bneck.com>".
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=bottleneck <noreply@bneck.com>

REDIS_URL=redis://localhost:6379

# Operator chat for webhook auto-disable / enqueue-failure alerts. Optional;
# falls back to BEARER_ADMIN_TELEGRAM_ID. Alerting no-ops if neither is set or
# outside production.
ALERT_TELEGRAM_CHAT_ID=

# Worker only: max ms to wait for in-flight webhook batches on SIGTERM before
# forcing close. Tune to ~2x observed p95 delivery time.
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
